# .env.example
# IFX MT5 Runtime — Environment variables
# Copy to .env and fill in values. NEVER commit .env to git.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# AES-256-GCM master key (32 bytes, base64-encoded)
# Generate with: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
MT5_CREDENTIALS_MASTER_KEY_B64=your-base64-master-key-here

# MT5 terminal paths
MT5_TERMINAL_TEMPLATE_DIR=C:\mt5-runtime\mt5-terminal-template
MT5_TERMINAL_BASE_DIR=C:\mt5-runtime\mt5-runtime-vps\terminals
MT5_TEST_TERMINAL_DIR=C:\mt5-runtime\mt5-test-terminal

# Debug flags (remove in production)
# IFX_CRASH_AFTER_ORDER=1

# Candle history (for chart backfill)
# - MT5_CANDLE_MAXBARS affects the Next.js in-memory 1m candle buffer used by /api/candles
# - RELAY_CANDLE_MAXBARS affects the VPS relay's persisted candle buffer
MT5_CANDLE_MAXBARS=10000
RELAY_CANDLE_MAXBARS=10000

# Optional: allow /api/candles to proxy to the VPS relay for deeper history.
# Useful for local dev when the relay is reachable from the Next.js server.
# Example: http://127.0.0.1:8082
PRICE_RELAY_URL=

# MT5 relay → Next.js ingest forwarding
# Set this so runtime/price_relay.py will forward MT5 tick batches to the UI backend.
# Example (local Next dev server): http://127.0.0.1:3000/api/mt5/ingest
RAILWAY_INGEST_URL=

# Optional: lock relay market-data ingestion to exactly one connection UUID.
# When set, price_relay ignores /tick-batch, /candle-close, /historical-bulk
# from any other connection_id. This lets you keep multiple accounts active
# while using one account as the single chart/price source.
RELAY_SOURCE_CONNECTION_ID=

# Optional Bearer token for the ingest endpoint.
# If you set this, also set RELAY_INGEST_TOKEN on the Next.js side.
RAILWAY_RELAY_TOKEN=
